# .env.example — copy to .env.local and fill in values for local development.
# Never commit .env.local or any file containing real secrets.
#
# §3.1 invariant: all API traffic goes through a single Application Gateway
# base URL. Do NOT split this into separate auth and API endpoints.

# Base URL of the Application Gateway (required).
# Local development: http://localhost:8006 — run the gateway in jwt mode so real
#   login tokens are accepted on protected routes (GATEWAY_AUTH_MODE=jwt).
# Self-hosted: the URL of your Oraclous gateway deployment
# Cloud-hosted: provided by Oraclous during onboarding
VITE_API_BASE_URL=http://localhost:8006
