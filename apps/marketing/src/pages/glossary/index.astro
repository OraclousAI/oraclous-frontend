---
import { glossary } from '../../lib/glossary';
import { SITE } from '../../lib/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const data = {
  title: 'Glossary — Oraclous terms defined',
  meta_description:
    'Definitions of every Oraclous term — Harness, OHM, ReBAC, BYOM, Operator, Agent, Capability, and more — each a self-contained, citable answer.',
  url: '/glossary',
  schema: ['BreadcrumbList'],
};

const definedTermSet = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Oraclous Glossary',
  url: `${SITE.url}/glossary`,
  hasDefinedTerm: glossary.map((e) => ({
    '@type': 'DefinedTerm',
    name: e.term,
    url: `${SITE.url}/glossary/${e.slug}`,
  })),
};
const ser = (o: unknown) => JSON.stringify(o).replace(/</g, '\\u003c');
---

<BaseLayout data={data} url="/glossary" kind="page">
  <script type="application/ld+json" is:inline set:html={ser(definedTermSet)} />
  <PageHero
    eyebrow="Reference"
    title="Glossary"
    lede="Every Oraclous term, defined once — the canonical, citable source. Each entry is a self-contained answer."
  />
  <section class="section">
    <div class="container">
      <dl class="glossary-list">
        {
          glossary.map((e) => (
            <div class="glossary-item reveal">
              <dt>
                <a href={`/glossary/${e.slug}`}>{e.term}</a>
              </dt>
              <dd>{e.definition}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>
</BaseLayout>
