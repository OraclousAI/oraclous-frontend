---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseFaq } from '../lib/faq';
import FabricMesh from '../components/diagrams/FabricMesh.astro';
import Handoff from '../components/diagrams/Handoff.astro';
import LayerStack from '../components/diagrams/LayerStack.astro';

const pages = await getCollection('pages');
const entry = pages.find((e) => e.data.url === '/');
if (!entry) throw new Error('Home page (front-matter `url: /`) not found in the `pages` collection.');

// FAQ rendered from the same source the FAQPage JSON-LD parses (single source of truth).
const faqs = parseFaq(entry.body ?? '').slice(0, 5);

const badChoices = [
  { t: 'Bespoke code', b: 'Fast to start — brittle and one-off. Every change is an engineering ticket.' },
  { t: 'Closed SaaS', b: 'Quick to adopt — but your data, governance, and exit belong to someone else.' },
  { t: 'Framework wiring', b: 'Reusable parts — but you rebuild governance, identity, and audit per use case.' },
];

const pillars = [
  { k: '01', t: 'One workforce', b: 'Humans and AI Agents are symmetric Actors on one task board, under one governance model.' },
  { k: '02', t: 'Describe the goal', b: 'Operators write goals in plain language; the platform compiles, governs, and runs them — no code per use case.' },
  { k: '03', t: 'Your data, your keys', b: "Self-host or cloud with identical guarantees. Every record is org-scoped; in cloud mode we can't decrypt your state." },
  { k: '04', t: 'Governance is the platform', b: 'ReBAC, policy sets, and provenance are substrate — enforced in code, not bolted on per project.' },
  { k: '05', t: 'Bring any model', b: 'BYOM across Anthropic-native, OpenAI-compatible, and Gemini-compatible. Switch by config; the Harness never moves.' },
  { k: '06', t: 'Open and honest', b: 'Open-source, ADR-documented, limits stated up front. Proof you can read — not metrics we invented.' },
];

const capabilities = [
  { t: 'Harness model', href: '/platform/harness-model', b: 'Compose humans + Agents, tasks, policies, and triggers into one runnable unit.' },
  { t: 'Bring your own model', href: '/platform/byom', b: 'Run the model you choose; the LLM is a resource, not the Agent.' },
  { t: 'Knowledge graph', href: '/platform/knowledge-graph', b: "Your org's provenance-tracked memory, retrieval bounded by ReBAC." },
  { t: 'ReBAC governance', href: '/platform/rebac-governance', b: 'Access by relationship, enforced platform-wide; code wins over prose.' },
  { t: 'Human-in-the-loop', href: '/platform/human-in-the-loop', b: 'A first-class runtime primitive — waiting on a human is like waiting on a tool.' },
  { t: 'Execution & scheduling', href: '/platform/execution-scheduling', b: 'Durable runs, checkpoints, schedules, retries — no runaway loops.' },
  { t: 'MCP & widgets', href: '/platform/mcp-widgets', b: 'MCP server and client; embed Agents into your product, host-safe.' },
  { t: 'Portability', href: '/platform/portability', b: 'OHM exports your work — with the limits stated, so there are no surprises.' },
];

const personas = [
  { t: 'Operations', href: '/solutions/operations', b: 'Ship agentic workflows without an engineering sprint.' },
  { t: 'Developers', href: '/solutions/developers', b: 'Build on the substrate, not the plumbing.' },
  { t: 'Regulated', href: '/solutions/regulated', b: 'Prove control — sovereignty and audit by architecture.' },
  { t: 'Multi-model', href: '/solutions/multi-model', b: 'Change the model. Keep the Harness.' },
];

const proofItems = ['Open source', 'ADR record', 'Honest docs', 'Per-service reference'];

// Real architecture constants — not invented metrics.
const proofStats = [
  { n: '5', l: 'versioned policy sets' },
  { n: '3', l: 'model protocols (BYOM)' },
  { n: '1', l: 'organisation boundary' },
  { n: '0', l: 'token markup' },
];
---

<BaseLayout data={entry.data} body={entry.body ?? ''} url="/" kind="home">
  {/* ── Hero ─────────────────────────────────────────────────────────────── */}
  <section class="hero surface-dark dotgrid">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy stagger">
        <p class="eyebrow eyebrow--live">The AI operating system for organisations</p>
        <h1 class="h-display">
          Your people and your AI, as one operational fabric<span
            class="hero-cursor is-blink"
            aria-hidden="true"></span>
        </h1>
        <p class="lede">
          Your data, tools, and AI are scattered — and people do the integration in their heads.
          Oraclous forms a <strong>harness</strong> around all of it: one governed fabric where human
          members and AI Agents share task boards, hand work back and forth, and run under one model
          of control.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/how-it-works"
            >See how it works <span class="arrow" aria-hidden="true">→</span></a
          >
          <a class="btn btn-ghost" href="/platform">Explore the platform</a>
        </div>
        <p class="hero-define">
          <span class="hero-define__label">second mind</span> — the unified operational fabric Oraclous
          forms around an organisation, where human members and AI Agents work side by side under the
          organisation's own access rules.
        </p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <FabricMesh />
      </div>
    </div>
  </section>

  {/* ── The fourth choice ────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The fourth choice</p>
        <h2 class="h-2">Teams deploying agents today get three bad options.</h2>
        <p class="lede">Each trades away something you'll miss — speed, sovereignty, or sanity.</p>
      </div>
      <div class="choices">
        {
          badChoices.map((c) => (
            <div class="choice reveal">
              <span class="choice__x" aria-hidden="true">
                ✕
              </span>
              <h3 class="choice__t">{c.t}</h3>
              <p class="choice__b">{c.b}</p>
            </div>
          ))
        }
        <div class="choice choice--win reveal">
          <span class="choice__check" aria-hidden="true">→</span>
          <h3 class="choice__t">Oraclous — the fourth</h3>
          <p class="choice__b">
            Describe the goal in prose. The platform compiles it, governs it with ReBAC, and runs it
            across humans and Agents — open-source, portable, your keys.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── One governed fabric (the mechanism) ──────────────────────────────── */}
  <section class="section surface-soft">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow">One governed fabric</p>
        <h2 class="h-2">Humans and Agents, side by side on one task board.</h2>
        <p class="lede">
          Work hands off both ways — a person assigns an Agent; an Agent escalates to a person — and
          every step runs under one model of control. Human-in-the-loop isn't bolted on: it's a gate
          the runtime enforces.
        </p>
      </div>
      <div class="split-art reveal"><Handoff /></div>
    </div>
  </section>

  {/* ── Value pillars ────────────────────────────────────────────────────── */}
  <section class="section surface-soft">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Why it's different</p>
        <h2 class="h-2">A governed fabric, not another agent framework.</h2>
      </div>
      <div class="grid grid-3">
        {
          pillars.map((p) => (
            <div class="card reveal">
              <span class="card__kicker">{p.k}</span>
              <h3 class="card__title">{p.t}</h3>
              <p class="card__body">{p.b}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Capabilities ─────────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The platform</p>
        <h2 class="h-2">One substrate. Every capability governed the same way.</h2>
        <p class="lede">
          Eight capabilities, one policy model — explore the platform, or jump straight in.
        </p>
      </div>
      <div class="grid grid-3">
        {
          capabilities.map((c) => (
            <a class="card" href={c.href}>
              <h3 class="card__title">{c.t}</h3>
              <p class="card__body">{c.b}</p>
              <span class="card__more">
                Learn more <span class="arrow" aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Enterprise-grade & sovereign ─────────────────────────────────────── */}
  <section class="section surface-dark dotgrid">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow eyebrow--live">Enterprise-grade by architecture</p>
        <h2 class="h-2">Your data stays yours — provably.</h2>
        <p class="lede">
          One layered platform on a substrate trust root: every record is organisation-scoped,
          credentials never leave the broker in plaintext, and in cloud mode we cannot decrypt your
          state. Governance (ReBAC) and audit are part of the substrate — not an add-on.
        </p>
        <div class="hero-cta">
          <a class="btn btn-ghost" href="/security"
            >Review the trust model <span class="arrow" aria-hidden="true">→</span></a
          >
        </div>
      </div>
      <div class="split-art reveal"><LayerStack /></div>
    </div>
  </section>

  {/* ── Honest proof ─────────────────────────────────────────────────────── */}
  <section class="section surface-dark">
    <div class="container">
      <div class="proof">
        <div class="section-head">
          <p class="eyebrow eyebrow--live">Proof, not promises</p>
          <h2 class="h-2">No invented metrics. No fake logos.</h2>
          <p class="lede">
            The proof is the architecture — open-source, decision-documented, with the trade-offs
            written down. You can read all of it before you commit a single workload.
          </p>
        </div>
        <ul class="proof-list">
          {
            proofItems.map((p) => (
              <li class="proof-item reveal">
                <span class="proof-item__dot" aria-hidden="true"></span>
                {p}
              </li>
            ))
          }
        </ul>
      </div>
      <dl class="proof-stats">
        {
          proofStats.map((s) => (
            <div class="stat reveal">
              <dt class="stat__n">{s.n}</dt>
              <dd class="stat__l">{s.l}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  {/* ── Persona doors ────────────────────────────────────────────────────── */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Where do you start?</p>
        <h2 class="h-2">Pick the path that matches your work.</h2>
      </div>
      <div class="grid grid-2">
        {
          personas.map((p) => (
            <a class="card persona" href={p.href}>
              <h3 class="card__title">{p.t}</h3>
              <p class="card__body">{p.b}</p>
              <span class="card__more">
                See the solution <span class="arrow" aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── FAQ ──────────────────────────────────────────────────────────────── */}
  {
    faqs.length > 0 && (
      <section class="section surface-soft">
        <div class="container faq">
          <div class="section-head">
            <p class="eyebrow">Questions</p>
            <h2 class="h-2">Frequently asked.</h2>
          </div>
          <div class="faq-list">
            {faqs.map((f) => (
              <details class="faq-item">
                <summary>
                  <span>{f.q}</span>
                  <span class="faq-item__sign" aria-hidden="true" />
                </summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* ── CTA band ─────────────────────────────────────────────────────────── */}
  <section class="section surface-dark dotgrid cta-band">
    <div class="container cta-inner">
      <h2 class="h-display cta-title">Form your second mind.</h2>
      <p class="lede cta-lede">
        Open-source, sovereign, and governed by your own rules. Start with the architecture — read
        exactly how it works before you commit.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/platform"
          >Start with the architecture <span class="arrow" aria-hidden="true">→</span></a
        >
        <a class="btn btn-ghost" href="/open-source">Read the source</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(var(--sp-16), 10vw, var(--sp-24));
  }
  .hero-glow {
    position: absolute;
    inset: auto -10% 30% auto;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 18%, transparent), transparent 62%);
    filter: blur(20px);
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: var(--sp-10);
  }
  .hero-copy {
    max-width: 38rem;
  }
  .h-display .accent {
    color: var(--accent);
    position: relative;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero .h-display .accent::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: -0.05em;
      height: 3px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      animation: m-underline 0.7s cubic-bezier(0.2, 0, 0.2, 1) 0.55s forwards;
    }
  }
  @keyframes m-underline {
    to {
      transform: scaleX(1);
    }
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-8);
  }
  .hero-define {
    margin: var(--sp-10) 0 0;
    padding-left: var(--sp-4);
    border-left: 2px solid color-mix(in oklab, var(--accent) 60%, transparent);
    color: var(--fg-mute);
    font-size: var(--t-body-size);
    line-height: 1.5;
    max-width: 50ch;
  }
  .hero-define__label {
    font-family: var(--font-mono);
    font-size: var(--t-caption-size);
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-right: var(--sp-1);
  }
  .hero-art {
    justify-self: center;
    width: 100%;
    max-width: 420px;
    color: var(--fg);
  }
  .hero-cursor {
    display: inline-block;
    width: 0.5ch;
    height: 0.82em;
    background: var(--accent);
    margin-left: 0.12em;
    vertical-align: -0.08em;
    border-radius: 1px;
  }
  .split {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(var(--sp-8), 5vw, var(--sp-16));
    align-items: center;
  }
  .split .section-head {
    margin-bottom: 0;
  }
  .split-art {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 460px;
    justify-self: center;
  }

  /* ── Fourth choice ────────────────────────────────────────────────────── */
  .choices {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--sp-4);
  }
  .choice {
    background: var(--bg);
    border: 1px solid var(--border-hair);
    border-radius: var(--r-4);
    padding: var(--sp-6);
  }
  .choice__x,
  .choice__check {
    font-family: var(--font-mono);
    font-size: var(--t-body-size);
    color: var(--fg-mute);
  }
  .choice__t {
    font-size: var(--t-h4-size);
    font-weight: 600;
    margin: var(--sp-3) 0 var(--sp-2);
  }
  .choice__b {
    margin: 0;
    color: var(--fg-mute);
    font-size: var(--t-body-size);
    line-height: 1.5;
  }
  .choice--win {
    background: color-mix(in oklab, var(--accent) 9%, var(--bg));
    border-color: color-mix(in oklab, var(--accent) 55%, var(--border-hair));
    box-shadow: var(--shadow-2);
  }
  .choice--win .choice__check {
    color: var(--fg);
    font-weight: 700;
  }

  /* ── Proof ────────────────────────────────────────────────────────────── */
  .proof {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--sp-10);
    align-items: center;
  }
  .proof .section-head {
    margin-bottom: 0;
  }
  .proof-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--sp-3);
  }
  .proof-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--t-h4-size);
    font-weight: 600;
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--border-hair);
  }
  .proof-item__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--accent);
    flex: none;
  }
  .proof-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--sp-6);
    margin: clamp(var(--sp-12), 6vw, var(--sp-16)) 0 0;
    padding-top: var(--sp-10);
    border-top: 1px solid var(--border-hair);
  }
  .stat {
    margin: 0;
  }
  .stat__n {
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--accent);
  }
  .stat__l {
    margin: var(--sp-2) 0 0;
    font-family: var(--font-mono);
    font-size: var(--t-caption-size);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }

  /* ── FAQ ──────────────────────────────────────────────────────────────── */
  .faq {
    max-width: 820px;
  }
  .faq-list {
    display: grid;
    gap: var(--sp-2);
  }
  .faq-item {
    border: 1px solid var(--border-hair);
    border-radius: var(--r-4);
    background: var(--bg);
    padding: 0 var(--sp-5);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5) 0;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: var(--t-body-lg-size);
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item__sign {
    position: relative;
    width: 14px;
    height: 14px;
    flex: none;
  }
  .faq-item__sign::before,
  .faq-item__sign::after {
    content: '';
    position: absolute;
    background: var(--accent);
    inset: 0;
    margin: auto;
  }
  .faq-item__sign::before {
    width: 14px;
    height: 2px;
  }
  .faq-item__sign::after {
    width: 2px;
    height: 14px;
    transition: transform var(--motion-hover-dur) var(--motion-hover-ease);
  }
  .faq-item[open] .faq-item__sign::after {
    transform: scaleY(0);
  }
  .faq-item p {
    margin: 0;
    padding: 0 0 var(--sp-5);
    color: var(--fg-mute);
    line-height: 1.55;
    max-width: 68ch;
  }

  /* ── CTA band ─────────────────────────────────────────────────────────── */
  .cta-band {
    text-align: center;
  }
  .cta-inner {
    max-width: 760px;
  }
  .cta-title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
  }
  .cta-lede {
    margin-inline: auto;
    margin-top: var(--sp-5);
  }
  .cta-band .hero-cta {
    justify-content: center;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-art {
      grid-row: 1;
      max-width: 280px;
      opacity: 0.85;
    }
    .proof,
    .split {
      grid-template-columns: 1fr;
    }
  }

</style>
