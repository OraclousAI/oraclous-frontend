---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => a.data.title.localeCompare(b.data.title));

const data = {
  title: 'Blog — agentic AI, governance & sovereignty | Oraclous',
  meta_description:
    'Articles on agentic AI governance, ReBAC, data sovereignty, bring-your-own-model, OHM portability, and the second mind.',
  url: '/blog',
  schema: ['Blog', 'BreadcrumbList'],
};

const postHref = (p: (typeof posts)[number]) => p.data.url ?? `/blog/${p.id}`;
---

<BaseLayout data={data} url="/blog" kind="page">
  <PageHero
    eyebrow="Resources"
    title="Field notes"
    lede="On agentic AI governance, data sovereignty, bring-your-own-model, and building a second mind your organisation actually controls."
  />
  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {
          sorted.map((p) => (
            <a class="card reveal" href={postHref(p)}>
              <span class="card__kicker">{p.data.category ?? 'Article'}</span>
              <h2 class="card__title">{p.data.title}</h2>
              <p class="card__body">{p.data.meta_description}</p>
              <span class="card__more">
                Read <span class="arrow" aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
