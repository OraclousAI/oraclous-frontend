---
/**
 * Human ↔ Agent handoff — work passes both ways across one task board, with a
 * human-in-the-loop gate on the return path (the live, mint step). Schematic, zero-JS,
 * reduced-motion-safe.
 */
const { class: cls } = Astro.props;
---

<svg
  class:list={['handoff', cls]}
  viewBox="0 0 520 180"
  role="img"
  aria-label="Work hands off both ways between a human and an AI Agent, gated by human-in-the-loop"
  fill="none"
>
  <!-- actors -->
  <g class="actor">
    <rect x="16" y="56" width="110" height="68" rx="10" />
    <circle cx="71" cy="82" r="9" />
    <path class="torso" d="M55 108 a16 16 0 0 1 32 0" />
    <text class="lbl" x="71" y="140" text-anchor="middle">HUMAN</text>
  </g>
  <g class="actor">
    <rect x="394" y="56" width="110" height="68" rx="10" />
    <rect class="agent-chip" x="436" y="73" width="26" height="26" rx="5" />
    <circle class="agent-eye" cx="445" cy="86" r="2.2" />
    <circle class="agent-eye" cx="453" cy="86" r="2.2" />
    <text class="lbl" x="449" y="140" text-anchor="middle">AGENT</text>
  </g>

  <!-- assign / hand off (top, → ) -->
  <path class="flow" d="M126 78 L382 78" marker-end="url(#ah-r)" />
  <rect class="card" x="238" y="68" width="34" height="22" rx="3" />
  <text class="lbl flow-lbl" x="255" y="58" text-anchor="middle">ASSIGN</text>

  <!-- review / escalate (bottom, ← ) through a HITL gate -->
  <path class="flow back" d="M382 104 L290 104" marker-end="url(#ah-l)" />
  <path class="flow back" d="M230 104 L126 104" />
  <g class="gate">
    <path class="gate-shape is-pulse" d="M260 90 l18 14 l-18 14 l-18 -14 Z" />
    <text class="lbl gate-lbl" x="260" y="142" text-anchor="middle">HITL</text>
  </g>

  <defs>
    <marker id="ah-r" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0 0 L8 4 L0 8 Z" fill="currentColor" />
    </marker>
    <marker id="ah-l" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0 0 L8 4 L0 8 Z" fill="var(--accent)" />
    </marker>
  </defs>
</svg>

<style>
  .handoff {
    width: 100%;
    height: auto;
    color: var(--fg);
    overflow: visible;
  }
  .actor rect {
    stroke: currentColor;
    stroke-width: 1.4;
    fill: color-mix(in oklab, var(--fg) 4%, transparent);
  }
  .actor circle,
  .actor .torso {
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
  }
  .agent-chip {
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
  }
  .agent-eye {
    fill: var(--accent);
    stroke: none;
  }
  .flow {
    stroke: currentColor;
    stroke-width: 1.5;
    opacity: 0.7;
  }
  .flow.back {
    stroke: var(--accent);
  }
  .card {
    stroke: currentColor;
    stroke-width: 1.3;
    fill: var(--bg);
  }
  .gate-shape {
    fill: color-mix(in oklab, var(--accent) 16%, var(--bg));
    stroke: var(--accent);
    stroke-width: 1.5;
  }
  .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    fill: var(--fg-mute);
  }
  .gate-lbl {
    fill: var(--fg);
  }
  @media (prefers-reduced-motion: no-preference) {
    .flow {
      stroke-dasharray: 300;
      stroke-dashoffset: 300;
      animation: m-draw 1.1s ease forwards;
    }
    .flow.back {
      animation-delay: 0.5s;
    }
  }
</style>
