---
/**
 * Compile flow — a left-to-right transform pipeline: a prose goal (a doc with text lines)
 * is compiled (a gear/box), passes a Review · HITL checkpoint (the live mint gate, the
 * only mint, non-text), and lands as a governed Harness (a structured block). Form =
 * stepped transform (prose → structured), with arrow markers between stages. Schematic,
 * zero-JS, reduced-motion-safe (connectors draw on motion; fully legible without it).
 */
const { class: cls } = Astro.props;
---

<svg
  class:list={['compile-flow', cls]}
  viewBox="0 0 540 180"
  role="img"
  aria-label="A pipeline that turns a prose goal into a governed Harness: describe the goal, the platform compiles it, you review at a human-in-the-loop checkpoint, then it runs."
  fill="none"
>
  <!-- stage 1: goal in prose (a document) -->
  <g class="stage">
    <rect class="paper" x="16" y="48" width="84" height="84" rx="6" />
    <line class="text-line" x1="30" y1="68" x2="86" y2="68" />
    <line class="text-line" x1="30" y1="80" x2="86" y2="80" />
    <line class="text-line" x1="30" y1="92" x2="74" y2="92" />
    <line class="text-line" x1="30" y1="104" x2="82" y2="104" />
    <text class="lbl" x="58" y="150" text-anchor="middle">GOAL · PROSE</text>
  </g>

  <path class="flow d1" d="M100 90 L136 90" marker-end="url(#cf-arrow)" />

  <!-- stage 2: compile (gear / box) -->
  <g class="stage">
    <rect class="box" x="140" y="58" width="74" height="64" rx="8" />
    <g class="gear">
      <circle cx="177" cy="90" r="13" />
      <circle class="gear-hub" cx="177" cy="90" r="4" />
      <line x1="177" y1="70" x2="177" y2="76" />
      <line x1="177" y1="104" x2="177" y2="110" />
      <line x1="157" y1="90" x2="163" y2="90" />
      <line x1="191" y1="90" x2="197" y2="90" />
    </g>
    <text class="lbl" x="177" y="150" text-anchor="middle">COMPILE</text>
  </g>

  <path class="flow d2" d="M214 90 L250 90" marker-end="url(#cf-arrow)" />

  <!-- stage 3: review · HITL (the live mint gate) -->
  <g class="stage gate">
    <path class="gate-shape is-pulse" d="M291 60 l24 30 l-24 30 l-24 -30 Z" />
    <path class="check" d="M281 90 l7 7 l13 -15" />
    <text class="lbl gate-lbl" x="291" y="150" text-anchor="middle">REVIEW · HITL</text>
  </g>

  <path class="flow live-edge d3" d="M324 90 L360 90" marker-end="url(#cf-arrow-a)" />

  <!-- stage 4: governed harness (a structured block) -->
  <g class="stage">
    <rect class="block" x="364" y="50" width="92" height="80" rx="8" />
    <rect class="slot" x="376" y="62" width="68" height="13" rx="2" />
    <rect class="slot" x="376" y="82" width="68" height="13" rx="2" />
    <rect class="slot" x="376" y="102" width="44" height="13" rx="2" />
    <text class="lbl" x="410" y="150" text-anchor="middle">GOVERNED HARNESS</text>
  </g>

  <defs>
    <marker id="cf-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0 0 L8 4 L0 8 Z" fill="currentColor" />
    </marker>
    <marker id="cf-arrow-a" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0 0 L8 4 L0 8 Z" fill="var(--accent)" />
    </marker>
  </defs>
</svg>

<style>
  .compile-flow {
    width: 100%;
    height: auto;
    color: var(--fg);
    overflow: visible;
  }
  .paper,
  .box,
  .block {
    stroke: currentColor;
    stroke-width: 1.5;
    fill: color-mix(in oklab, var(--fg) 4%, transparent);
  }
  .text-line {
    stroke: currentColor;
    stroke-width: 1.3;
    opacity: 0.45;
  }
  .gear circle,
  .gear line {
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
  }
  .gear-hub {
    fill: currentColor;
    stroke: none;
  }
  .slot {
    fill: currentColor;
    opacity: 0.16;
    stroke: none;
  }
  .gate-shape {
    fill: color-mix(in oklab, var(--accent) 14%, var(--bg));
    stroke: var(--accent);
    stroke-width: 1.5;
  }
  .check {
    stroke: var(--accent);
    stroke-width: 1.6;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .flow {
    stroke: currentColor;
    stroke-width: 1.5;
    opacity: 0.7;
  }
  .flow.live-edge {
    stroke: var(--accent);
    opacity: 1;
  }
  .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    fill: var(--fg-mute);
  }
  .gate-lbl {
    fill: var(--fg);
  }
  @media (prefers-reduced-motion: no-preference) {
    .flow {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: m-draw 0.8s ease forwards;
    }
    .flow.d2 {
      animation-delay: 0.25s;
    }
    .flow.d3 {
      animation-delay: 0.5s;
    }
  }
</style>
