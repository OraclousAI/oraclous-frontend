---
import { segLabel } from '../lib/labels';

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const segs = url.split('/').filter(Boolean);
const crumbs: { name: string; href: string | null }[] = [{ name: 'Home', href: '/' }];
let path = '';
segs.forEach((seg, i) => {
  path += `/${seg}`;
  const isLast = i === segs.length - 1;
  crumbs.push({ name: isLast ? title : segLabel(seg), href: isLast ? null : path });
});
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol>
    {
      crumbs.map((c) => (
        <li>
          {c.href ? <a href={c.href}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    max-width: 76ch;
    margin: var(--sp-6) auto 0;
    padding: 0 var(--sp-5);
  }
  .breadcrumbs ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    padding: 0;
    margin: 0;
    font-size: var(--t-caption-size);
    color: var(--fg-mute);
  }
  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: var(--sp-2);
    color: var(--fg-mute);
  }
  .breadcrumbs a {
    color: var(--fg-mute);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    color: var(--ink);
    text-decoration: underline;
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--ink);
  }
</style>
